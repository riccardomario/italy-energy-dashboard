# Copy this file to .streamlit/secrets.toml and fill in the real values.
# secrets.toml is gitignored and never committed.
#
# On Streamlit Community Cloud, paste the same content into the
# app's Settings -> Secrets panel in the web UI.

ENTSOE_API_TOKEN = "your-entsoe-token-here"
DASHBOARD_PASSWORD = "choose-a-password"
